// ==================== 系统配置模块类型定义 ====================

// 获取配置列表请求
type GetConfigListReq {
    PaginationReq
    Key   string `json:"key,optional" form:"key,optional"`   // 配置键（模糊查询）
    Name  string `json:"name,optional" form:"name,optional"` // 配置名称（模糊查询）
    Group string `json:"group,optional" form:"group,optional"` // 配置分组
}

// 获取配置列表响应
type GetConfigListResp {
    Code       int                 `json:"code"`       // 状态码
    Message    string              `json:"message"`    // 消息
    Pagination PaginationResp      `json:"pagination"` // 分页信息
    Data       []ConfigListItem    `json:"data"`       // 配置列表
}

// 配置列表项
type ConfigListItem {
    Id          int64  `json:"id"`          // 配置ID
    Key         string `json:"key"`         // 配置键
    Name        string `json:"name"`        // 配置名称
    Value       string `json:"value"`       // 配置值
    Type        string `json:"type"`        // 配置类型
    Group       string `json:"group"`       // 配置分组
    Description string `json:"description"` // 配置描述
    Status      int    `json:"status"`      // 状态
    CreatedAt   int64  `json:"createdAt"`   // 创建时间
    UpdatedAt   int64  `json:"updatedAt"`   // 更新时间
}

// 根据键获取配置请求
type GetConfigByKeyReq {
    Key string `json:"key,optional" path:"key"` // 配置键
}

// 根据键获取配置响应
type GetConfigByKeyResp {
    Code    int          `json:"code"`    // 状态码
    Message string       `json:"message"` // 消息
    Data    ConfigDetail `json:"data"`   // 配置详情
}

// 配置详情
type ConfigDetail {
    Id          int64  `json:"id"`          // 配置ID
    Key         string `json:"key"`         // 配置键
    Name        string `json:"name"`        // 配置名称
    Value       string `json:"value"`       // 配置值
    Type        string `json:"type"`        // 配置类型
    Group       string `json:"group"`       // 配置分组
    Description string `json:"description"` // 配置描述
    Status      int    `json:"status"`      // 状态
    CreatedAt   int64  `json:"createdAt"`   // 创建时间
    UpdatedAt   int64  `json:"updatedAt"`   // 更新时间
}

// 创建配置请求
type CreateConfigReq {
    Key         string `json:"key"`         // 配置键
    Name        string `json:"name"`        // 配置名称
    Value       string `json:"value"`       // 配置值
    Type        string `json:"type"`        // 配置类型
    Group       string `json:"group,optional"`       // 配置分组
    Description string `json:"description,optional"` // 配置描述
    Status      int    `json:"status,optional"`      // 状态
}

// 创建配置响应
type CreateConfigResp {
    Code    int    `json:"code"`    // 状态码
    Message string `json:"message"` // 消息
    ConfigId int64 `json:"configId"` // 配置ID
}

// 更新配置请求
type UpdateConfigReq {
    Key         string `json:"key,optional" path:"key"` // 配置键
    Name        string `json:"name,optional"`            // 配置名称
    Value       string `json:"value,optional"`           // 配置值
    Description string `json:"description,optional"`     // 配置描述
    Status      int    `json:"status,optional"`          // 状态
}

// 更新配置响应
type UpdateConfigResp {
    Code    int    `json:"code"`    // 状态码
    Message string `json:"message"` // 消息
}

// 删除配置请求
type DeleteConfigReq {
    Key string `json:"key,optional" path:"key"` // 配置键
}

// 删除配置响应
type DeleteConfigResp {
    Code    int    `json:"code"`    // 状态码
    Message string `json:"message"` // 消息
}
